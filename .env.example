# Server Configuration
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# MySQL Database Configuration
DB_HOST=your_database_host
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_CONNECTION_LIMIT=10

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# OneSignal Configuration
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_API_KEY=your_onesignal_api_key

# Social OAuth - Google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Social OAuth - Facebook
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/facebook/callback

# Social OAuth - Apple (Optional)
APPLE_CLIENT_ID=your_apple_services_id
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY_PATH=./config/AuthKey_XXXXXXXXXX.p8
APPLE_CALLBACK_URL=http://localhost:3000/api/auth/apple/callback

# n8n Integration (To be configured later)
N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.com/webhook
N8N_WEBHOOK_SECRET=your_n8n_webhook_secret
USE_N8N_LLM=false
USE_N8N_TTS=false
USE_N8N_MODERATION_ASYNC=false
USE_N8N_PERSONA_CONFIG=false
PERSONA_PROMPT_CACHE_MS=300000
# Must be a public callback base URL reachable from n8n
# Example: https://api.yourdomain.com (avoid https://...:3000)
NODE_INTERNAL_BASE_URL=https://your-api-domain.com
# In production this is already strict by default; set true to enforce in non-prod too
N8N_CONFIG_STRICT=false
N8N_STARTUP_SMOKE_TEST=false
N8N_SMOKE_TIMEOUT_MS=8000
# Optional smoke test credentials
N8N_SMOKE_TTS_VOICE_ID=
N8N_SMOKE_TTS_TEXT=Hello from smoke test.

# OpenAI LLM Configuration
OPENAI_API_KEY=your_openai_key
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_VOICE_MODEL=gpt-4o-mini
OPENAI_MODERATION_MODEL=omni-moderation-latest
# Moderation tuning:
# - Flagged soft categories can pass below threshold (soft warn + continue)
# - Any non-soft flagged category still hard-blocks
MODERATION_HARD_BLOCK_THRESHOLD=0.70
MODERATION_SOFT_CATEGORIES=violence,violence/graphic

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:19006
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# OpenAI / Streaming STT
STT_REALTIME_MODEL=gpt-realtime-mini
STT_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
STT_SAMPLE_RATE=16000
STT_CHUNK_MS=200
# Lower values commit transcript earlier (recommended voice-call tune: 800)
STT_MAX_LAG_MS=800
STT_PARTIAL_THROTTLE_MS=150
STT_STREAM_ENABLED=true
STT_ALLOW_LOCAL_FALLBACK=false
STT_SESSION_MINUTE_LIMIT=15

# TTS chunking / first-audio tuning
TTS_FIRST_CHUNK_MIN_CHARS=20
TTS_FIRST_CHUNK_MIN_WORDS=3

# Arşiv Voice/Video Gateway — kademeli rollout için default kapalı.
# Production'da feature-flag servisi ile aç/kapa.
VOICE_STREAMING_ENABLED=false
VIDEO_CALL_ENABLED=false
VOICE_DEBUG_LOGS=false
VIDEO_DEBUG_LOGS=false
VOICE_PERSIST_TO_CHAT=false
VOICE_DEFAULT_LANGUAGE=tr-TR
VOICE_AUDIO_CODEC=pcm16le
VOICE_AUDIO_SAMPLE_RATE=16000
VOICE_AUDIO_CHANNELS=1
VOICE_AUDIO_FRAME_MS=20
VOICE_VAD_SILENCE_MS=900

# STT Provider Selection
# openai-realtime | openai-whisper | deepgram | mock
STT_PROVIDER=openai-realtime
STT_MIN_AUDIO_BYTES=3200
STT_MIN_TRANSCRIPT_CHARS=2

# Deepgram (optional)
DEEPGRAM_API_KEY=

# Whisper REST (optional fallback)
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_STT_PROMPT=Türkçe konuşmayı doğru yaz. Belirsiz sesi uydurma.
OPENAI_STT_TEMPERATURE=0

# ElevenLabs (voiceId default; persona_voices tablosundaki override eder)
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Viseme
VISEME_ENABLED=true
# remote | elevenlabs | rhubarb
VISEME_PROVIDER=remote
VISEME_BLOCKING=false
VISEME_MIN_GAP_SEC=0.04
VISEME_RHUBARB_BIN=/opt/rhubarb/rhubarb
VISEME_FFMPEG_BIN=ffmpeg

# WebRTC
WEBRTC_ENABLED=false
WEBRTC_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]
